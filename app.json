{
  "expo": {
    "name": "Symptom Journal",
    "slug": "symptom-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cody.symptomjournal"
    },
    "android": {
      "package": "com.cody.symptomjournal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "anthropicKey": "EXPO_PUBLIC_ANTHROPIC_KEY",
      "eas": {
        "projectId": "209c01f5-586b-4718-a355-d89aedb86ec6"
      }
    }
  }
}
